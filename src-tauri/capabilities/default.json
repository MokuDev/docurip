{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
    "permissions": [
    "core:default",
    "shell:allow-open",
    "fs:default",
    "dialog:default",
    "store:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir"
  ]
}
